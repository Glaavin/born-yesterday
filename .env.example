# Born Yesterday — required environment variable NAMES (template; NO real values).
#
# Real values live ONLY in .env.local (gitignored) and the Vercel env store.
# Provisioned by the Neon integration. Ignore the legacy POSTGRES_* aliases.

# POOLED connection — used by the RUNTIME serverless DB client (src/db/client.ts).
DATABASE_URL=

# DIRECT/UNPOOLED connection — used by MIGRATIONS (drizzle-kit) and `pnpm db:check`.
DATABASE_URL_UNPOOLED=
